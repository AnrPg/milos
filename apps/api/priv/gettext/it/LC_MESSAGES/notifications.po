msgstr "Il tuo allenatore ha rimosso un allenamento programmato."

msgid "Workout rejected"
msgstr "Allenamento rifiutato"

msgid "An athlete"
msgstr "Un atleta"

msgid "a workout"
msgstr "un allenamento"

msgid "%{nickname} rejected %{title}."
msgstr "%{nickname} rifiutato %{title}."

msgid "Workout rescheduled"
msgstr "Allenamento riprogrammato"

