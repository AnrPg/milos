msgstr "Hai ricevuto un nuovo messaggio."

msgid "Milos Training"
msgstr "Allenamento di Milo"

msgid "You have a new notification."
msgstr "Hai una nuova notifica."

msgid "invoice"
msgstr "fattura"

msgid "New invoice"
msgstr "Nuova fattura"

msgid "Invoice %{invoice_number} has been issued for your account."
msgstr "La fattura %{invoice_number} è stata emessa per il tuo account."

msgid "Payment reminder"
msgstr "Promemoria di pagamento"

msgid "You have an outstanding balance of %{amount} due."
msgstr "Hai un saldo dovuto di %{amount} dovuto."
